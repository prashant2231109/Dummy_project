              'link': 'https://www.djangoproject.com/weblog/2026/feb/24/google-summer-of-code-2026-with-django/',
              'links': [{'href': 'https://www.djangoproject.com/weblog/2026/feb/24/google-summer-of-code-2026-with-django/',
