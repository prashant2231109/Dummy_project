             {'author': 'Djangonaut Space Mission Control',
              'author_detail': {'name': 'Djangonaut Space Mission Control'},
              'authors': [{'name': 'Djangonaut Space Mission Control'}],
              'guidislink': False,
              'id': 'https://www.djangoproject.com/weblog/2026/jan/21/djangonaut-space-session-6-accepting-applications/',
              'link': 'https://www.djangoproject.com/weblog/2026/jan/21/djangonaut-space-session-6-accepting-applications/',
              'links': [{'href': 'https://www.djangoproject.com/weblog/2026/jan/21/djangonaut-space-session-6-accepting-applications/',
